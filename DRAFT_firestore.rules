rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isTeacher() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Schemas ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['student', 'teacher', 'admin'] &&
               (data.get('points', 0) is number) &&
               (!data.keys().contains('points') || data.points >= 0);
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.role == 'teacher'; // Teachers can list all kids
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'student'; // Default to student
      allow update: if (isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        // Action: Self update profile (restricted fields)
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'grade', 'class', 'number', 'bio']))
      )) || isAdmin();
    }

    // --- Questions ---
    match /questions/{questionId} {
      function isValidQuestion(data) {
        return data.keys().hasAll(['content', 'authorId', 'createdAt']) &&
               data.content is string && data.content.size() <= 5000 &&
               data.authorId == request.auth.uid &&
               data.createdAt == request.time &&
               (data.get('likesCount', 0) is number);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(questionId) && isValidQuestion(incoming());
      allow update: if (isSignedIn() && (
        // Action: Self edit content
        (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'tags', 'category', 'updatedAt']) && incoming().updatedAt == request.time && incoming().authorId == existing().authorId) ||
        // Action: Like increment (simplified for demo, usually needs a subcollection for unique likes)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && incoming().likesCount == existing().likesCount + 1) ||
        // Action: AI Feedback
        (isTeacher() && incoming().diff(existing()).affectedKeys().hasOnly(['aiFeedback']))
      )) || isAdmin();
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    // --- Comments ---
    match /questions/{questionId}/comments/{commentId} {
      function isValidComment(data) {
        return data.keys().hasAll(['content', 'authorId', 'createdAt', 'questionId']) &&
               data.content is string && data.content.size() <= 1000 &&
               data.authorId == request.auth.uid &&
               data.createdAt == request.time &&
               data.questionId == questionId;
      }
      
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming()) && exists(/databases/$(database)/documents/questions/$(questionId));
      allow update: if isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content']);
      allow delete: if isOwner(existing().authorId) || isAdmin() || isTeacher();
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }
  }
}
